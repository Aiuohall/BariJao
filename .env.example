# Copy this file to ".env" and fill in real values. NEVER commit your real .env.
# Leaving the Supabase variables empty makes the app run on a local, self-contained
# SQLite database (no external service required).

# --- Database (optional) ---
# To use Supabase (persistent Postgres), set these. If left empty, SQLite is used.
SUPABASE_URL=
SUPABASE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Google Gemini AI (optional) ---
# Powers the "generate listing description" feature. Leave empty to disable it.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
VITE_GOOGLE_AI_API_KEY=

# --- Auth ---
# A long random string used to sign login tokens. Generate your own.
JWT_SECRET=change_me_to_a_long_random_string

# --- Server ---
PORT=3000
