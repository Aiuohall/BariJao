# Copy this file to ".env" and fill in real values. NEVER commit your real .env.
# Leaving the Supabase variables empty makes the app run on a local, self-contained
# SQLite database (no external service required).

# --- Database (optional) ---
# To use Supabase (persistent Postgres), set these. If left empty, SQLite is used.
SUPABASE_URL=
SUPABASE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Google Gemini AI (optional) ---
# Powers the "generate listing description" feature. Leave empty to disable it.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
VITE_GOOGLE_AI_API_KEY=

# --- Email (OTP delivery) ---
# Simplest setup is Gmail with an "App Password" (requires 2-Step Verification on
# your Google account, then create one at https://myaccount.google.com/apppasswords).
# Leave empty to skip email (the OTP will only be logged to the server console).
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=BariJao <your-gmail@gmail.com>
# Advanced: to use a non-Gmail provider, also set SMTP_HOST / SMTP_PORT / SMTP_SECURE.

# --- Auth ---
# A long random string used to sign login tokens. Generate your own.
JWT_SECRET=change_me_to_a_long_random_string

# --- Server ---
PORT=3000
